#!/usr/bin/env python3

# https://github.com/swaywm/sway/issues/4346

import json
import subprocess

result = subprocess.run(
    ["swaymsg", "-t", "get_outputs"],
    capture_output=True,
    text=True,
    check=True,
)

outputs = json.loads(result.stdout)
active = [o for o in outputs if o.get("active") is True]

focused_index = next(i for i, o in enumerate(active) if o.get("focused"))
next_name = active[(focused_index + 1) % len(active)]["name"]

print(next_name)
