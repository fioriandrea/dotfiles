#! /bin/bash

clock=$(date '+%I')
clockIcon=

case "$clock" in
	"00") clockIcon="¯Äü" ;;
	"01") clockIcon="¯Äé" ;;
	"02") clockIcon="¯Äâ" ;;
	"03") clockIcon="¯Ää" ;;
	"04") clockIcon="¯Äà" ;;
	"05") clockIcon="¯Äå" ;;
	"06") clockIcon="¯Äç" ;;
	"07") clockIcon="¯Äê" ;;
	"08") clockIcon="¯Äë" ;;
	"09") clockIcon="¯Äè" ;;
	"10") clockIcon="¯Äè" ;;
	"11") clockIcon="¯Äî" ;;
	"12") clockIcon="¯Äü" ;;
esac

date "+%Y %b %d (%a) $clockIcon %I:%M%p"
