set -o vi

if [[ ${EUID} == 0 ]] ; then
    PS1='\[\033[01;31m\][\h\[\033[01;36m\] \W\[\033[01;31m\]]\$\[\033[00m\] '
else
    PS1='\[\033[01;32m\][\u@\h\[\033[01;37m\] \W\[\033[01;32m\]]\$\[\033[00m\] '
fi

fzfsettings="fzf/settings"
[ -f "$XDG_CONFIG_HOME/$fzfsettings" ] && . "$XDG_CONFIG_HOME/$fzfsettings"

alias info='info --vi-keys'
alias diff='diff --color=auto'

# dotfiles management

alias ricegit='/usr/bin/git --git-dir=$HOME/.myconf/ --work-tree=$HOME'

neofetch
