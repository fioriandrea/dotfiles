set -o vi

if [[ ${EUID} == 0 ]] ; then
    PS1='\[\033[01;31m\][\h\[\033[01;36m\] \W\[\033[01;31m\]]\$\[\033[00m\] '
else
    PS1='\[\033[01;32m\][\u@\h\[\033[01;37m\] \W\[\033[01;32m\]]\$\[\033[00m\] '
fi

xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"

fzfconfig="fzf/fzf-config.sh"
[ -f "$xdg_config_home/$fzfconfig" ] && . "$xdg_config_home/$fzfconfig"

nnnconfig="nnn/nnn-config.sh"
[ -f "$xdg_config_home/$nnnconfig" ] && . "$xdg_config_home/$nnnconfig" 

alias info='info --vi-keys'
alias diff='diff --color=auto'

# dotfiles management

alias ricegit='/usr/bin/git --git-dir=$HOME/.myconf/ --work-tree=$HOME'

neofetch
