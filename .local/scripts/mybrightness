#!/usr/bin/env bash

set -euo pipefail

readonly default_fraction=0.01

usage() {
    cat <<'EOF'
usage: mybrightness [up|down|set|status] [STEP_FRACTION]
EOF
}

print_status() {
    local value
    value=$(brightnessctl -m | awk -F, '{ printf("%s (%d)\n", $4, $3) }')
    printf 'Brightness: %s\n' "$value"
}

cmd="${1:-status}"
step_fraction="${2:-$default_fraction}"
step_fraction="${step_fraction#-}"

max=$(brightnessctl max)
step=$(awk -v m="$max" -v f="$step_fraction" 'BEGIN { printf "%d", m*f }')

case "$cmd" in
    up)
        brightnessctl set "+${step}" >/dev/null
        print_status
        ;;
    down)
        brightnessctl set "${step}-" >/dev/null
        print_status
        ;;
    set)
        brightnessctl set "${step}" >/dev/null
        print_status
        ;;
    status)
        print_status
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
