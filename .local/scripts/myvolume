#!/usr/bin/env bash

set -euo pipefail

readonly default_sink="@DEFAULT_AUDIO_SINK@"
readonly default_source="@DEFAULT_AUDIO_SOURCE@"
readonly default_fraction=0.01

usage() {
    cat <<'EOF'
usage: myvolume [up|down|mute|status|mic-up|mic-down|mic-mute|mic-status] [FRACTION]
EOF
}

volume_percent() {
    local target="$1"
    wpctl get-volume "$target" | awk '{ printf "%d", $2 * 100 }'
}

volume_muted() {
    local target="$1"
    wpctl get-volume "$target" | grep -q '\[MUTED\]'
}

print_status() {
    local label="$1"
    local target="$2"
    local percent muted_str
    percent=$(volume_percent "$target")
    muted_str=""
    if volume_muted "$target"; then
        muted_str=' [muted]'
    fi
    printf '%s: %s%%%s\n' "$label" "$percent" "$muted_str"
}

cmd="${1:-status}"
fraction="${2:-$default_fraction}"
fraction="${fraction#-}"

case "$cmd" in
    up)
        wpctl set-volume "$default_sink" "${fraction}+"
        print_status "Volume" "$default_sink"
        ;;
    down)
        wpctl set-volume "$default_sink" "${fraction}-"
        print_status "Volume" "$default_sink"
        ;;
    mute)
        wpctl set-mute "$default_sink" toggle
        print_status "Volume" "$default_sink"
        ;;
    status)
        print_status "Volume" "$default_sink"
        ;;
    mic-up)
        wpctl set-volume "$default_source" "${fraction}+"
        print_status "Microphone" "$default_source"
        ;;
    mic-down)
        wpctl set-volume "$default_source" "${fraction}-"
        print_status "Microphone" "$default_source"
        ;;
    mic-mute)
        wpctl set-mute "$default_source" toggle
        print_status "Microphone" "$default_source"
        ;;
    mic-status)
        print_status "Microphone" "$default_source"
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
